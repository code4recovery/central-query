# Environment Variables Example
# Copy this file to `.env` for local development

# MongoDB Configuration (required)
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=central-query-dev

# Server Configuration
PORT=5001
NODE_ENV=development

# Notes:
# - E2E tests use MongoDB Memory Server and don't need .env (see README.e2e.md)
# - Unit tests use MongoDB Memory Server and don't need .env
# - Production uses Google Secret Manager for MONGO_URI and MONGO_DB_NAME
