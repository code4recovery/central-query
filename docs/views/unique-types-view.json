[
  {
    "$unwind": "$types"
  },
  {
    "$group": {
      "_id": "$types"
    }
  },
  {
    "$lookup": {
      "from": "type",
      "localField": "_id",
      "foreignField": "code",
      "as": "details"
    }
  },
  {
    "$unwind": "$details"
  },
  {
    "$replaceRoot": {
      "newRoot": {
        "$mergeObjects": ["$$ROOT", "$details"]
      }
    }
  },
  {
    "$project": {
      "details": 0,
      "_id": 0
    }
  }
]